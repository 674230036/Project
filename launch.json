{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "เปิดด้วย Chrome ตรงๆ (ไม่ต้องมี Server)",
            "file": "${workspaceFolder}/index.html"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "รันผ่าน Live Server (Port 5500)",
            "url": "http://localhost:5500/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost:8080",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}